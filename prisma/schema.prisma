generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  super_admin
  admin
  manager
  viewer
}

enum Theme {
  dark
  light
  system
}

enum AuditAction {
  login_succeeded
  login_failed
  password_reset_requested
  password_reset_completed
  user_created
  user_updated
  user_deleted
  user_role_changed
  user_access_granted
  user_access_revoked
  user_activated
  user_deactivated
  profile_updated
  profile_password_changed
  email_change_requested
  email_change_completed
  account_switched
  setting_updated
  opened_chatwoot_link
  session_revoked
}

model User {
  id                  String              @id @default(uuid()) @db.Uuid
  email               String              @unique
  password            String
  name                String
  platformRole        PlatformRole        @default(viewer) @map("platform_role")
  isOwner             Boolean             @default(false) @map("is_owner")
  isActive            Boolean             @default(true) @map("is_active")
  mustChangePassword  Boolean             @default(true) @map("must_change_password")
  passwordChangedAt   DateTime?           @map("password_changed_at")
  avatarUrl           String?             @map("avatar_url")
  theme               Theme               @default(system)
  emailVerifiedAt     DateTime?           @map("email_verified_at")
  lastLoginAt         DateTime?           @map("last_login_at")
  lastLoginIp         String?             @map("last_login_ip")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  createdById         String?             @db.Uuid @map("created_by_id")
  createdBy           User?               @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers        User[]              @relation("UserCreator")
  accountAccess       UserAccountAccess[]
  teamAccess          UserTeamAccess[]
  audits              AuditLog[]
  passwordResetTokens PasswordResetToken[]
  emailChangeTokens   EmailChangeToken[]

  @@index([platformRole, isActive])
  @@index([email])
  @@map("users")
}

model UserAccountAccess {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatwootAccountId   Int      @map("chatwoot_account_id")
  chatwootAccountName String   @map("chatwoot_account_name")
  grantedAt           DateTime @default(now()) @map("granted_at")
  grantedById         String?  @db.Uuid @map("granted_by_id")

  @@unique([userId, chatwootAccountId])
  @@index([chatwootAccountId])
  @@map("user_account_access")
}

model UserTeamAccess {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatwootAccountId Int      @map("chatwoot_account_id")
  chatwootTeamId    Int      @map("chatwoot_team_id")
  chatwootTeamName  String   @map("chatwoot_team_name")
  grantedAt         DateTime @default(now()) @map("granted_at")

  @@unique([userId, chatwootAccountId, chatwootTeamId])
  @@index([userId, chatwootAccountId])
  @@map("user_team_access")
}

model AppSetting {
  key         String   @id
  value       Json
  description String?
  category    String
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @db.Uuid @map("updated_by_id")

  @@map("app_settings")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid @map("user_id")
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  targetType String?     @map("target_type")
  targetId   String?     @map("target_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  details    Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model EmailChangeToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail   String    @map("new_email")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("email_change_tokens")
}

model LlmConfig {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String
  model           String
  encryptedApiKey String?  @map("encrypted_api_key")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @db.Uuid @map("created_by_id")
  credentialId    String?  @db.Uuid @map("credential_id")

  @@map("llm_configs")
}

model LlmCredential {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String
  label           String
  encryptedApiKey String   @map("encrypted_api_key")
  last4           String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @db.Uuid @map("created_by_id")

  @@unique([provider, label], name: "llm_credentials_provider_label_idx")
  @@index([provider, updatedAt(sort: Desc)], name: "llm_credentials_provider_updated_idx")
  @@map("llm_credentials")
}

model LlmUsage {
  id            String   @id @default(uuid()) @db.Uuid
  provider      String
  model         String
  tokensInput   Int      @map("tokens_input")
  tokensOutput  Int      @map("tokens_output")
  costUsd       Decimal  @map("cost_usd") @db.Decimal(10, 6)
  promptChars   Int      @map("prompt_chars")
  responseChars Int      @map("response_chars")
  userId        String?  @db.Uuid @map("user_id")
  durationMs    Int?     @map("duration_ms")
  errorMessage  String?  @map("error_message")
  costBrl       Decimal? @map("cost_brl") @db.Decimal(12, 6)
  usdToBrlRate  Decimal? @map("usd_to_brl_rate") @db.Decimal(10, 4)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([provider, model, createdAt])
  @@map("llm_usage")
}

model ChatwootFactsDailyByAccount {
  accountId       Int      @map("account_id")
  bucketDate      DateTime @map("bucket_date") @db.Date
  received        Int      @default(0)
  resolved        Int      @default(0)
  openAtEod       Int      @default(0) @map("open_at_eod")
  pendingAtEod    Int      @default(0) @map("pending_at_eod")
  messagesIn      Int      @default(0) @map("messages_in")
  messagesOut     Int      @default(0) @map("messages_out")
  uniqueContacts  Int      @default(0) @map("unique_contacts")
  frtP50Seconds   Int?     @map("frt_p50_seconds")
  frtP90Seconds   Int?     @map("frt_p90_seconds")
  rtP50Seconds    Int?     @map("rt_p50_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([accountId, bucketDate])
  @@index([accountId, bucketDate(sort: Desc)])
  @@map("chatwoot_facts_daily_by_account")
}

model ChatwootFactsDailyByInbox {
  accountId       Int      @map("account_id")
  bucketDate      DateTime @map("bucket_date") @db.Date
  inboxId         Int      @map("inbox_id")
  received        Int      @default(0)
  resolved        Int      @default(0)
  openAtEod       Int      @default(0) @map("open_at_eod")
  pendingAtEod    Int      @default(0) @map("pending_at_eod")
  messagesIn      Int      @default(0) @map("messages_in")
  messagesOut     Int      @default(0) @map("messages_out")
  uniqueContacts  Int      @default(0) @map("unique_contacts")
  frtP50Seconds   Int?     @map("frt_p50_seconds")
  frtP90Seconds   Int?     @map("frt_p90_seconds")
  rtP50Seconds    Int?     @map("rt_p50_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([accountId, bucketDate, inboxId])
  @@index([accountId, bucketDate(sort: Desc)])
  @@index([accountId, inboxId, bucketDate(sort: Desc)])
  @@map("chatwoot_facts_daily_by_inbox")
}

model ChatwootFactsDailyByAgent {
  accountId       Int      @map("account_id")
  bucketDate      DateTime @map("bucket_date") @db.Date
  agentId         Int      @map("agent_id")
  received        Int      @default(0)
  resolved        Int      @default(0)
  openAtEod       Int      @default(0) @map("open_at_eod")
  pendingAtEod    Int      @default(0) @map("pending_at_eod")
  messagesIn      Int      @default(0) @map("messages_in")
  messagesOut     Int      @default(0) @map("messages_out")
  uniqueContacts  Int      @default(0) @map("unique_contacts")
  frtP50Seconds   Int?     @map("frt_p50_seconds")
  frtP90Seconds   Int?     @map("frt_p90_seconds")
  rtP50Seconds    Int?     @map("rt_p50_seconds")
  isActiveAtEod   Boolean  @default(true) @map("is_active_at_eod")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([accountId, bucketDate, agentId])
  @@index([accountId, bucketDate(sort: Desc)])
  @@index([accountId, agentId, bucketDate(sort: Desc)])
  @@map("chatwoot_facts_daily_by_agent")
}

model ChatwootFactsDailyByTeam {
  accountId       Int      @map("account_id")
  bucketDate      DateTime @map("bucket_date") @db.Date
  // teamId=0 sentinel for 'no team'
  teamId          Int      @default(0) @map("team_id")
  received        Int      @default(0)
  resolved        Int      @default(0)
  openAtEod       Int      @default(0) @map("open_at_eod")
  pendingAtEod    Int      @default(0) @map("pending_at_eod")
  messagesIn      Int      @default(0) @map("messages_in")
  messagesOut     Int      @default(0) @map("messages_out")
  uniqueContacts  Int      @default(0) @map("unique_contacts")
  frtP50Seconds   Int?     @map("frt_p50_seconds")
  frtP90Seconds   Int?     @map("frt_p90_seconds")
  rtP50Seconds    Int?     @map("rt_p50_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([accountId, bucketDate, teamId])
  @@index([accountId, bucketDate(sort: Desc)])
  @@index([accountId, teamId, bucketDate(sort: Desc)])
  @@map("chatwoot_facts_daily_by_team")
}

model ChatwootFactsHourlyByAccount {
  accountId       Int      @map("account_id")
  bucketDate      DateTime @map("bucket_date") @db.Date
  bucketHour      Int      @map("bucket_hour")
  received        Int      @default(0)
  resolved        Int      @default(0)
  messagesIn      Int      @default(0) @map("messages_in")
  messagesOut     Int      @default(0) @map("messages_out")
  uniqueContacts  Int      @default(0) @map("unique_contacts")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([accountId, bucketDate, bucketHour])
  @@index([accountId, bucketDate(sort: Desc), bucketHour])
  @@map("chatwoot_facts_hourly_by_account")
}

model ChatwootFactsMeta {
  dimension         String
  accountId         Int       @map("account_id")
  lastRefreshAt     DateTime? @map("last_refresh_at")
  lastAttemptAt     DateTime? @map("last_attempt_at")
  lastError         String?   @map("last_error") @db.Text
  oldestBucketDate  DateTime? @map("oldest_bucket_date") @db.Date
  newestBucketDate  DateTime? @map("newest_bucket_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@id([dimension, accountId])
  @@map("chatwoot_facts_meta")
}
