# =====================================================
# Nexus Insights — Variáveis de ambiente
#
# Copiar para .env.local (dev) ou .env.production (prod)
# .env.production NUNCA deve ser commitado.
# =====================================================

# ---- Banco do Nexus Insights (nosso DB) ----
DATABASE_URL="postgresql://nexus:${DB_PASSWORD}@db:5432/nexus_insights?schema=public"
DB_PASSWORD="change-me-openssl-rand-base64-24"

# ---- Banco do Chatwoot (read-only) ----
CHATWOOT_DATABASE_URL="postgresql://chatwoot_leitura:CHANGE_ME@HOST:5432/chatwoot"
CHATWOOT_BASE_URL="https://chatwoot.SEU-DOMINIO.com.br"

# ---- Redis ----
REDIS_URL="redis://redis:6379"

# ---- Auth (gerar valores únicos para produção) ----
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://insights.SEU-DOMINIO.com"

# ---- Encryption (32 bytes hex = 64 chars) ----
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ---- Owner inicial (seed) ----
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_NAME="Administrador"

# ---- Email (Resend) ----
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Nexus Insights <noreply@SEU-DOMINIO.com>"

# ---- Integrações (Power BI) ----
INTEGRATION_DB_HOST_PUBLIC="db.insights.nexusai360.com"
INTEGRATION_DB_PORT_PUBLIC="5432"
INTEGRATION_DB_NAME_PUBLIC="nexus_insights"
INTEGRATION_PROFILE_SOFT_CAP="50"

# ---- App ----
NODE_ENV="production"
APP_VERSION="dev"
